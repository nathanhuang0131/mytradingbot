#################################
# Trading Mode
#################################

# Supported aliases:
# - DEFAULT_MODE
# - RUNTIME__DEFAULT_MODE
DEFAULT_MODE=paper
LIVE_TRADING_ENABLED=false

#################################
# Alpaca Broker
#################################

# Supported aliases:
# - ALPACA_API_KEY
# - BROKER__ALPACA_API_KEY
ALPACA_API_KEY=
# Supported aliases:
# - ALPACA_SECRET_KEY
# - BROKER__ALPACA_SECRET_KEY
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex
ALPACA_ADJUSTMENT=raw

#################################
# LLM Advisory (optional)
#################################

OPENAI_API_KEY=
LLM_ENABLED=false

#################################
# Logging
#################################

LOG_LEVEL=INFO

PYTHON_ENV=mytradingbot
